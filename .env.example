# research-library MCP server — environment
# Copy to .env and fill in. NEVER commit .env (it is gitignored).

# Supabase (required) — service-role key, server-side only, never ship to a client.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI (required for semantic-search / embedding tools)
OPENAI_API_KEY=sk-your-openai-key

# HTTP server port (remote/ChatGPT mode). Defaults to 3000.
PORT=3000

# Optional prototype auth for the HTTP /mcp endpoint. If set, callers must send
# `Authorization: Bearer <token>`. If unset, /mcp is unauthenticated (dev only).
MCP_BEARER_TOKEN=

# Expose only the read-only tools (29 of 37) over HTTP — recommended for a public,
# service-role-backed endpoint. Read by http.ts only; stdio (Claude) always serves
# the full toolset. Set to 1 for the ChatGPT/remote endpoint.
MCP_READONLY=1
